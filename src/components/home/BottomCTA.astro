---
interface Props {
  heading?: string;
  subtitle?: string;
  primaryText?: string;
  primaryHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  heading = 'Ready to clear the bottleneck?',
  subtitle = 'See how Metrias can accelerate your discharge throughput, recover revenue, and free your clinical team.',
  primaryText = 'Request Demo',
  primaryHref = 'mailto:contact@metriasmedical.com?subject=Demo%20Request',
  secondaryText = 'Contact Us',
  secondaryHref = 'mailto:contact@metriasmedical.com?subject=Contact%20Request',
} = Astro.props;
---

<section class="relative overflow-hidden bg-provider-blue-dark py-24 md:py-32">
  <div class="absolute inset-0 bg-gradient-to-r from-provider-blue-dark/95 to-provider-blue/80"></div>

  <div class="relative mx-auto max-w-4xl px-6 text-center lg:px-8">
    <h2 class="font-heading text-[32px] leading-tight font-bold text-white md:text-[52px] md:leading-tight">
      {heading}
    </h2>

    <p class="mx-auto mt-6 max-w-2xl font-body text-lg text-white/80">
      {subtitle}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={secondaryHref}
        class="rounded-lg border-2 border-white/80 px-8 py-3 font-body text-base font-medium text-white transition-colors hover:bg-white/10"
      >
        {secondaryText}
      </a>
      <a
        href={primaryHref}
        class="rounded-lg bg-ai-gold px-8 py-3 font-body text-base font-medium text-provider-blue transition-colors hover:bg-ai-gold/90"
      >
        {primaryText}
      </a>
    </div>
  </div>
</section>
