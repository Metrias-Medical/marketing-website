---
import SEOHead from '../components/global/SEOHead.astro';
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, ogImage, ogType } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
    />
  </head>
  <body class="min-h-screen bg-off-white text-black font-body">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
