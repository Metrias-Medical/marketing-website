---
const navLinks = [
  { label: 'Home', href: '/' },
  // { label: 'For Hospitals', href: '/hospitals' },
  // { label: 'For Investors', href: '/investors' },
  { label: 'About Us', href: '/about' },
  // { label: 'Product & Portal', href: '/product' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-navbar"
  class="fixed top-0 left-0 right-0 z-50 h-18 bg-white/95 backdrop-blur-sm transition-shadow duration-300"
>
  <nav class="mx-auto flex h-full max-w-7xl items-center justify-between px-6 lg:px-8" aria-label="Main navigation">
    <a href="/" class="shrink-0" aria-label="Metrias Medical home">
      <img
        src="/images/Metrias Medical _ Stacled-edge-OG.png"
        alt="Metrias Medical"
        width="120"
        height="48"
        class="h-12 w-auto"
      />
    </a>

    <ul class="hidden items-center gap-8 lg:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-body text-base font-semibold transition-colors hover:text-provider-blue',
              isActive(link.href)
                ? 'text-provider-blue border-b-2 border-ai-gold pb-0.5'
                : 'text-payer-slate',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-4">
      <a
        href="mailto:contact@metriasmedical.com?subject=Demo%20Request"
        class="hidden rounded-lg bg-ai-gold px-5 py-2.5 font-body text-base font-medium text-provider-blue transition-colors hover:bg-ai-gold/90 sm:inline-block"
      >
        Request Demo
      </a>

      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center rounded-lg p-2 text-payer-slate lg:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden border-t border-border-gray bg-white lg:hidden"
  >
    <ul class="flex flex-col gap-1 px-6 py-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block rounded-lg px-4 py-3 font-body text-base font-semibold transition-colors hover:bg-light-gray hover:text-provider-blue',
              isActive(link.href)
                ? 'bg-light-gray text-provider-blue'
                : 'text-payer-slate',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2">
        <a
          href="mailto:contact@metriasmedical.com?subject=Demo%20Request"
          class="block rounded-lg bg-ai-gold px-4 py-3 text-center font-body text-base font-medium text-provider-blue transition-colors hover:bg-ai-gold/90"
        >
          Request Demo
        </a>
      </li>
    </ul>
  </div>
</header>

<div class="h-18"></div>

<script>
  const navbar = document.getElementById('site-navbar');
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  let scrolled = false;
  const onScroll = () => {
    const shouldShadow = window.scrollY > 8;
    if (shouldShadow !== scrolled) {
      scrolled = shouldShadow;
      navbar?.classList.toggle('shadow-md', scrolled);
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
